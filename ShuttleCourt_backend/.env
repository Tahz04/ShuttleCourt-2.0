# ===============================

# APP CONFIG

# ===============================

PORT=5000
NODE_ENV=development

# ===============================

# DATABASE CONFIG (MySQL Docker)

# ===============================

DB_HOST=mysql
DB_PORT=3306
DB_NAME=badminton_booking
DB_USER=root
DB_PASSWORD=root

# ===============================

# JWT AUTH

# ===============================

JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=7d

# ===============================

# ADMIN DEFAULT ACCOUNT

# ===============================

ADMIN_EMAIL=[admin@gmail.com](mailto:admin@gmail.com)
ADMIN_PASSWORD=admin123

# ===============================

# FILE UPLOAD

# ===============================

UPLOAD_PATH=uploads
MAX_FILE_SIZE=5000000
